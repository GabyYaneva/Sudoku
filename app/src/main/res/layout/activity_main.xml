<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_background">


    <!-- Logo-->
    <ImageView
        android:id="@+id/appLogo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="64dp"
        android:src="@drawable/my_logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Title -->
    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="SUDOKU"
        android:textSize="36sp"
        android:fontFamily="@font/fredoka_regular"
        android:textColor="@color/light_text"
        android:letterSpacing="0.15"
        app:layout_constraintTop_toBottomOf="@id/appLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Difficulty label -->
    <TextView
        android:id="@+id/selectLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Select Difficulty"
        android:textSize="18sp"
        android:fontFamily="@font/fredoka_regular"
        android:textColor="@color/light_text"
        app:layout_constraintTop_toBottomOf="@id/appTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Easy -->
    <Button
        android:id="@+id/btnEasy"
        android:layout_width="200dp"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:text="Easy"
        android:fontFamily="@font/fredoka_regular"
        android:textSize="18sp"
        android:backgroundTint="@color/light_accent"
        android:textColor="@color/light_text"
        app:layout_constraintTop_toBottomOf="@id/selectLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Medium -->
    <Button
        android:id="@+id/btnMedium"
        android:layout_width="200dp"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="Medium"
        android:fontFamily="@font/fredoka_regular"
        android:textSize="18sp"
        android:backgroundTint="@color/light_accent"
        android:textColor="@color/light_text"
        app:layout_constraintTop_toBottomOf="@id/btnEasy"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Hard -->
    <Button
        android:id="@+id/btnHard"
        android:layout_width="200dp"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:text="Hard"
        android:fontFamily="@font/fredoka_regular"
        android:textSize="18sp"
        android:backgroundTint="@color/light_accent"
        android:textColor="@color/light_text"
        app:layout_constraintTop_toBottomOf="@id/btnMedium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Continue — only visible if saved game exists -->
    <Button
        android:id="@+id/btnContinue"
        android:layout_width="200dp"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:text="Continue"
        android:fontFamily="@font/fredoka_regular"
        android:textSize="18sp"
        android:backgroundTint="@color/light_surface"
        android:textColor="@color/light_text"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/btnHard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Theme toggle top right -->
    <ImageView
        android:id="@+id/btnTheme"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_margin="20dp"
        android:padding="15dp"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_brightness"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="Toggle theme"/>
</androidx.constraintlayout.widget.ConstraintLayout>